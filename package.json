{
  "name": "broken-vault",
  "version": "1.0.0",
  "description": "A deliberately insecure Notes App for learning OWASP Top 10 vulnerabilities",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "build:css:prod": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify"
  },
  "keywords": [
    "security",
    "owasp",
    "sqli",
    "xss",
    "education"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "isomorphic-dompurify": "^2.9.0",
    "jsdom": "^23.0.1",
    "mysql2": "^3.6.5",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.1"
  }
}
